<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Badabing</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0a0a0f;
            --surface: #111118;
            --surface2: #1a1a26;
            --border: rgba(255,255,255,0.07);
            --accent: #c8ff00;
            --accent2: #ff4d6d;
            --accent3: #7b61ff;
            --text: #e8e8f0;
            --muted: #6b6b80;
            --card-bg: #13131e;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background-color: var(--bg);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            font-size: 15px;
            line-height: 1.6;
            min-height: 100vh;
            background-image:
                radial-gradient(ellipse 60% 40% at 80% 0%, rgba(123,97,255,0.12) 0%, transparent 60%),
                radial-gradient(ellipse 40% 30% at 10% 80%, rgba(200,255,0,0.06) 0%, transparent 50%);
        }

        .navbar {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(10,10,15,0.85);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border);
            padding: 0 2rem;
            display: flex;
            align-items: center;
            gap: 0;
            height: 60px;
        }

        .navbar-brand {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.7rem;
            letter-spacing: 2px;
            color: var(--accent);
            text-decoration: none;
            margin-right: auto;
            position: relative;
        }
        .navbar-brand::after {
            content: 'SPACE';
            font-size: 0.55rem;
            letter-spacing: 4px;
            color: var(--muted);
            display: block;
            line-height: 0;
            margin-top: -4px;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 0.25rem;
        }

        .nav-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
            color: var(--muted);
            font-size: 0.85rem;
            font-weight: 500;
            padding: 0.4rem 0.9rem;
            border-radius: 6px;
            transition: color 0.2s, background 0.2s;
            font-family: 'Space Mono', monospace;
            letter-spacing: -0.3px;
        }
        .nav-link:hover { color: var(--text); background: rgba(255,255,255,0.05); }
        .nav-link.logout {
            color: var(--accent2);
            border: 1px solid rgba(255,77,109,0.3);
            margin-left: 0.5rem;
        }
        .nav-link.logout:hover { background: rgba(255,77,109,0.1); }

        .search-form {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin: 0 1.5rem;
        }

        .search-input {
            background: var(--surface2);
            border: 1px solid var(--border);
            color: var(--text);
            padding: 0.42rem 0.9rem;
            border-radius: 6px;
            font: 0.82rem 'DM Sans', sans-serif;
            width: 200px;
            transition: border-color 0.2s, width 0.3s;
            outline: none;
        }
        .search-input:focus {
            border-color: rgba(200,255,0,0.4);
            width: 240px;
        }
        .search-input::placeholder { color: var(--muted); }

        .search-select {
            background: var(--surface2);
            border: 1px solid var(--border);
            color: var(--muted);
            padding: 0.42rem 0.6rem;
            border-radius: 6px;
            font: 0.82rem 'DM Sans', sans-serif;
            outline: none;
            cursor: pointer;
        }
        .search-select:focus { border-color: rgba(200,255,0,0.4); }

        .search-btn {
            background: var(--accent);
            color: #0a0a0f;
            border: none;
            padding: 0.42rem 1rem;
            border-radius: 6px;
            font: 700 0.8rem 'Space Mono', monospace;
            cursor: pointer;
            letter-spacing: 0.5px;
            transition: opacity 0.2s, transform 0.15s;
        }
        .search-btn:hover { opacity: 0.85; transform: translateY(-1px); }

        .page-wrap {
            max-width: 900px;
            margin: 0 auto;
            padding: 2rem 1.5rem 4rem;
        }

        .card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 1.5rem;
        }

        .field-label {
            display: block;
            font: 700 0.78rem 'Space Mono', monospace;
            color: var(--muted);
            letter-spacing: 0.8px;
            text-transform: uppercase;
            margin-bottom: 0.4rem;
        }

        .field-input, .field-textarea, .field-select {
            width: 100%;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            padding: 0.65rem 0.9rem;
            font: 0.9rem 'DM Sans', sans-serif;
            outline: none;
            transition: border-color 0.2s;
            margin-bottom: 1rem;
        }
        .field-input:focus, .field-textarea:focus, .field-select:focus {
            border-color: rgba(200,255,0,0.5);
        }
        .field-input::placeholder, .field-textarea::placeholder { color: var(--muted); }
        .field-textarea { min-height: 100px; resize: vertical; }

        .page-heading {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 3rem;
            letter-spacing: 2px;
            line-height: 1;
            margin-bottom: 0.25rem;
        }
        .page-sub {
            color: var(--muted);
            font-size: 0.9rem;
            margin-bottom: 2rem;
        }

        .empty-state {
            text-align: center;
            padding: 3rem 1rem;
            color: var(--muted);
            border: 1px dashed var(--border);
            border-radius: 12px;
            font-family: 'Space Mono', monospace;
        }

        .error-msg {
            background: rgba(255,77,109,0.1);
            border: 1px solid rgba(255,77,109,0.3);
            color: var(--accent2);
            border-radius: 8px;
            padding: 0.65rem 1rem;
            font-size: 0.85rem;
            margin-bottom: 1rem;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(18px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .animate-in { animation: fadeUp 0.45s ease both; }
        .delay-1 { animation-delay: 0.1s; }
        .delay-2 { animation-delay: 0.2s; }
        .delay-3 { animation-delay: 0.3s; }
    </style>
</head>
<body>
    <nav class="navbar">
        <a href="/explore" class="navbar-brand">Badabing</a>

        <form class="search-form" action="/explore/search" method="get">
            <input class="search-input" type="text" name="search" placeholder="Search anything...">
            <select class="search-select" name="searchBy">
                <option value="tag">By Tag</option>
                <option value="profile">By Profile</option>
            </select>
            <button class="search-btn" type="submit">GO</button>
        </form>

        <div class="nav-links">
            <a href="/explore" class="nav-link">Feed</a>
            <a href="/profile" class="nav-link">Profile</a>
            <a href="/logout" class="nav-link logout">Logout</a>
        </div>
    </nav>
