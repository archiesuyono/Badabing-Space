<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Badabing Space — Register</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0a0a0f;
            --surface: #111118;
            --surface2: #1a1a26;
            --border: rgba(255,255,255,0.07);
            --accent: #c8ff00;
            --accent2: #ff4d6d;
            --accent3: #7b61ff;
            --text: #e8e8f0;
            --muted: #6b6b80;
        }
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

        .panel-left {
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 4rem 3.5rem;
            position: relative;
            overflow: hidden;
        }
        .panel-left::before {
            content: '';
            position: absolute;
            top: -30%; right: -20%;
            width: 70%; height: 80%;
            background: radial-gradient(ellipse, rgba(200,255,0,0.12), transparent 70%);
        }
        .panel-left::after {
            content: '';
            position: absolute;
            bottom: -20%; left: -10%;
            width: 50%; height: 60%;
            background: radial-gradient(ellipse, rgba(123,97,255,0.12), transparent 70%);
        }

        .brand-logo {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 4rem;
            letter-spacing: 3px;
            line-height: 1;
            position: relative; z-index: 1;
        }
        .brand-logo em { color: var(--accent); font-style: normal; }

        .steps {
            margin-top: 2.5rem;
            position: relative; z-index: 1;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }
        .step {
            display: flex;
            align-items: flex-start;
            gap: 1rem;
        }
        .step-num {
            font: 700 0.75rem 'Space Mono', monospace;
            background: rgba(200,255,0,0.12);
            color: var(--accent);
            border: 1px solid rgba(200,255,0,0.25);
            border-radius: 50%;
            width: 28px; height: 28px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .step-text strong { display: block; font-size: 0.88rem; color: var(--text); }
        .step-text span { font-size: 0.8rem; color: var(--muted); }

        .panel-right {
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 3rem 3.5rem;
            overflow-y: auto;
        }

        .form-heading {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2.4rem;
            letter-spacing: 2px;
            margin-bottom: 0.3rem;
        }
        .form-sub {
            color: var(--muted);
            font-size: 0.88rem;
            margin-bottom: 2rem;
        }

        .errors-block {
            background: rgba(255,77,109,0.08);
            border: 1px solid rgba(255,77,109,0.25);
            border-radius: 8px;
            padding: 0.9rem 1rem;
            margin-bottom: 1.5rem;
        }
        .errors-block p {
            color: var(--accent2);
            font-size: 0.84rem;
            margin: 0;
            padding: 0.15rem 0;
        }
        .errors-block p::before { content: '— '; }

        .field-group { margin-bottom: 1rem; }
        .field-label {
            display: block;
            font: 700 0.72rem 'Space Mono', monospace;
            color: var(--muted);
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 0.4rem;
        }
        .field-input {
            width: 100%;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            padding: 0.72rem 1rem;
            font: 0.9rem 'DM Sans', sans-serif;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .field-input:focus {
            border-color: rgba(200,255,0,0.5);
            box-shadow: 0 0 0 3px rgba(200,255,0,0.07);
        }
        .field-input::placeholder { color: var(--muted); }
        .field-input[type="date"] { color-scheme: dark; }

        .submit-btn {
            width: 100%;
            background: var(--accent);
            color: #0a0a0f;
            border: none;
            border-radius: 8px;
            padding: 0.82rem;
            font: 700 0.88rem 'Space Mono', monospace;
            letter-spacing: 1px;
            cursor: pointer;
            margin-top: 0.3rem;
            transition: opacity 0.2s, transform 0.15s;
        }
        .submit-btn:hover { opacity: 0.88; transform: translateY(-1px); }

        .form-footer {
            margin-top: 1.5rem;
            padding-top: 1.2rem;
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 0.8rem;
        }
        .form-footer span { color: var(--muted); font-size: 0.85rem; }
        .back-link {
            text-decoration: none;
            color: var(--accent3);
            font: 600 0.85rem 'DM Sans', sans-serif;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }
        .back-link:hover { text-decoration: underline; }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .animate-in { animation: fadeUp 0.45s ease both; }
        .d1 { animation-delay: 0.05s; }
        .d2 { animation-delay: 0.12s; }
        .d3 { animation-delay: 0.18s; }
        .d4 { animation-delay: 0.24s; }
        .d5 { animation-delay: 0.30s; }
        .d6 { animation-delay: 0.36s; }

        @media (max-width: 680px) {
            body { grid-template-columns: 1fr; }
            .panel-left { display: none; }
            .panel-right { padding: 3rem 1.5rem; }
        }
    </style>
</head>
<body>
    <div class="panel-left">
        <div class="brand-logo"><em>Bad</em>abing<br>Space.</div>
        <div class="steps">
            <div class="step">
                <div class="step-num">1</div>
                <div class="step-text">
                    <strong>Create your account</strong>
                    <span>Fill in the form to get started</span>
                </div>
            </div>
            <div class="step">
                <div class="step-num">2</div>
                <div class="step-text">
                    <strong>Set up your profile</strong>
                    <span>Add a photo and bio</span>
                </div>
            </div>
            <div class="step">
                <div class="step-num">3</div>
                <div class="step-text">
                    <strong>Start posting</strong>
                    <span>Share your thoughts with the space</span>
                </div>
            </div>
        </div>
    </div>

    <div class="panel-right">
        <div class="animate-in d1">
            <h1 class="form-heading">Create Account</h1>
            <p class="form-sub">Join Badabing Space today</p>
        </div>

        <% if (errors) { %>
        <% errors = errors.split(",") %>
        <div class="errors-block animate-in d1">
            <% errors.forEach(error => { %>
            <p><%= error %></p>
            <% }) %>
        </div>
        <% } %>

        <form action="/start/register" method="post">
            <div class="field-group animate-in d2">
                <label class="field-label">Username</label>
                <input class="field-input" type="text" name="username" placeholder="your_username" autocomplete="username">
            </div>

            <div class="field-group animate-in d3">
                <label class="field-label">Email</label>
                <input class="field-input" type="email" name="email" placeholder="you@example.com" autocomplete="email">
            </div>

            <div class="field-group animate-in d4">
                <label class="field-label">Password</label>
                <input class="field-input" type="password" name="password" placeholder="Min. 7 characters" autocomplete="new-password">
            </div>

            <div class="field-group animate-in d5">
                <label class="field-label">Date of Birth</label>
                <input class="field-input" type="date" name="dateOfBirth">
            </div>

            <div class="animate-in d6">
                <button class="submit-btn" type="submit">CREATE ACCOUNT →</button>
            </div>
        </form>

        <div class="form-footer animate-in d6">
            <span>Already have an account?</span>
            <a href="/start" class="back-link">← Sign in</a>
        </div>
    </div>
</body>
</html>
