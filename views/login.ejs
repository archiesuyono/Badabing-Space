<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Badabing Space — Login</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0a0a0f;
            --surface: #111118;
            --surface2: #1a1a26;
            --border: rgba(255,255,255,0.07);
            --accent: #c8ff00;
            --accent2: #ff4d6d;
            --accent3: #7b61ff;
            --text: #e8e8f0;
            --muted: #6b6b80;
        }
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

        .panel-left {
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 4rem 3.5rem;
            position: relative;
            overflow: hidden;
        }
        .panel-left::before {
            content: '';
            position: absolute;
            top: -30%; left: -20%;
            width: 70%; height: 80%;
            background: radial-gradient(ellipse, rgba(123,97,255,0.18), transparent 70%);
        }
        .panel-left::after {
            content: '';
            position: absolute;
            bottom: -20%; right: -10%;
            width: 50%; height: 60%;
            background: radial-gradient(ellipse, rgba(200,255,0,0.1), transparent 70%);
        }

        .brand-logo {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 5rem;
            letter-spacing: 4px;
            color: var(--text);
            line-height: 1;
            position: relative;
            z-index: 1;
        }
        .brand-logo em {
            color: var(--accent);
            font-style: normal;
        }
        .brand-tagline {
            font-size: 0.95rem;
            color: var(--muted);
            margin-top: 1.2rem;
            max-width: 280px;
            line-height: 1.7;
            position: relative;
            z-index: 1;
        }

        .deco-grid {
            position: absolute;
            bottom: 2rem; right: 2rem;
            width: 120px; height: 120px;
            background-image: radial-gradient(circle, rgba(255,255,255,0.12) 1px, transparent 1px);
            background-size: 14px 14px;
            opacity: 0.5;
        }

        .panel-right {
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 4rem 3.5rem;
        }

        .form-heading {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2.4rem;
            letter-spacing: 2px;
            margin-bottom: 0.3rem;
        }
        .form-sub {
            color: var(--muted);
            font-size: 0.88rem;
            margin-bottom: 2.2rem;
        }

        .field-group { margin-bottom: 1.1rem; }

        .field-label {
            display: block;
            font: 700 0.72rem 'Space Mono', monospace;
            color: var(--muted);
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 0.45rem;
        }

        .field-input {
            width: 100%;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            padding: 0.75rem 1rem;
            font: 0.92rem 'DM Sans', sans-serif;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .field-input:focus {
            border-color: rgba(200,255,0,0.5);
            box-shadow: 0 0 0 3px rgba(200,255,0,0.07);
        }
        .field-input::placeholder { color: var(--muted); }

        .error-msg {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,77,109,0.1);
            border: 1px solid rgba(255,77,109,0.3);
            color: var(--accent2);
            border-radius: 8px;
            padding: 0.65rem 1rem;
            font-size: 0.85rem;
            margin-bottom: 1.5rem;
        }

        .submit-btn {
            width: 100%;
            background: var(--accent);
            color: #0a0a0f;
            border: none;
            border-radius: 8px;
            padding: 0.85rem;
            font: 700 0.9rem 'Space Mono', monospace;
            letter-spacing: 1px;
            cursor: pointer;
            margin-top: 0.5rem;
            transition: opacity 0.2s, transform 0.15s;
        }
        .submit-btn:hover { opacity: 0.88; transform: translateY(-1px); }

        .form-footer {
            margin-top: 1.8rem;
            padding-top: 1.5rem;
            border-top: 1px solid var(--border);
            text-align: center;
        }
        .form-footer p { color: var(--muted); font-size: 0.85rem; margin-bottom: 0.75rem; }

        .register-btn {
            display: inline-block;
            text-decoration: none;
            border: 1px solid var(--border);
            color: var(--text);
            padding: 0.65rem 2rem;
            border-radius: 8px;
            font: 600 0.85rem 'DM Sans', sans-serif;
            transition: background 0.2s, border-color 0.2s;
        }
        .register-btn:hover { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.15); }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .animate-in { animation: fadeUp 0.5s ease both; }
        .d1 { animation-delay: 0.05s; }
        .d2 { animation-delay: 0.12s; }
        .d3 { animation-delay: 0.19s; }
        .d4 { animation-delay: 0.26s; }

        @media (max-width: 680px) {
            body { grid-template-columns: 1fr; }
            .panel-left { display: none; }
            .panel-right { padding: 3rem 1.5rem; }
        }
    </style>
</head>
<body>
    <div class="panel-left">
        <div class="brand-logo"><em>Bad</em>abing<br>Space.</div>
        <p class="brand-tagline">Your corner of the internet. Post what you feel, tag what matters, connect with the vibes.</p>
        <div class="deco-grid"></div>
    </div>

    <div class="panel-right">
        <div class="animate-in d1">
            <h1 class="form-heading">Welcome Back</h1>
            <p class="form-sub">Sign in to your account</p>
        </div>

        <% if (error) { %>
        <div class="error-msg animate-in d1">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <%= error %>
        </div>
        <% } %>

        <form action="/start" method="post">
            <div class="field-group animate-in d2">
                <label class="field-label">Email</label>
                <input class="field-input" type="email" name="email" placeholder="you@example.com" autocomplete="email">
            </div>

            <div class="field-group animate-in d3">
                <label class="field-label">Password</label>
                <input class="field-input" type="password" name="password" placeholder="••••••••" autocomplete="current-password">
            </div>

            <div class="animate-in d4">
                <button class="submit-btn" type="submit">SIGN IN →</button>
            </div>
        </form>

        <div class="form-footer animate-in d4">
            <p>Don't have an account yet?</p>
            <a href="/start/register" class="register-btn">Create Account</a>
        </div>
    </div>
</body>
</html>
