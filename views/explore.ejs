<%- include('header') %>
<style>
    .explore-layout {
        display: grid;
        grid-template-columns: 1fr 260px;
        gap: 1.5rem;
        max-width: 980px;
        margin: 2rem auto;
        padding: 0 1.5rem;
    }

    .composer {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.5rem;
    }
    .composer-trigger {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 1.4rem;
        cursor: pointer;
        transition: background 0.2s;
    }
    .composer-trigger:hover { background: rgba(255,255,255,0.03); }

    .composer-avatar {
        width: 36px; height: 36px;
        background: var(--accent3);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font: 700 0.85rem 'Space Mono', monospace;
        color: #fff;
        flex-shrink: 0;
    }
    .composer-placeholder {
        flex: 1;
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 0.55rem 1rem;
        font: 0.88rem 'DM Sans', sans-serif;
        color: var(--muted);
        cursor: pointer;
        transition: border-color 0.2s;
    }
    .composer-placeholder:hover { border-color: rgba(255,255,255,0.15); }

    .composer-expand-btn {
        background: none;
        border: 1px solid var(--border);
        color: var(--muted);
        border-radius: 6px;
        padding: 0.4rem 0.75rem;
        font: 700 0.75rem 'Space Mono', monospace;
        cursor: pointer;
        transition: all 0.2s;
        letter-spacing: 0.5px;
    }
    .composer-expand-btn:hover, .composer-expand-btn.active {
        background: rgba(200,255,0,0.08);
        border-color: rgba(200,255,0,0.3);
        color: var(--accent);
    }

    .composer-body {
        display: none;
        padding: 0 1.4rem 1.4rem;
        border-top: 1px solid var(--border);
        animation: fadeDown 0.25s ease;
    }
    .composer-body.open { display: block; }

    @keyframes fadeDown {
        from { opacity: 0; transform: translateY(-8px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .composer-body .field-label { margin-top: 1rem; }

    .post-submit-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 1rem;
    }
    .post-submit-btn {
        background: var(--accent);
        color: #0a0a0f;
        border: none;
        border-radius: 6px;
        padding: 0.6rem 1.8rem;
        font: 700 0.82rem 'Space Mono', monospace;
        letter-spacing: 0.8px;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.15s;
    }
    .post-submit-btn:hover { opacity: 0.85; transform: translateY(-1px); }

    .feed-header {
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
        margin-bottom: 1.2rem;
    }
    .feed-heading {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 1.6rem;
        letter-spacing: 1.5px;
    }
    .feed-count {
        font: 0.78rem 'Space Mono', monospace;
        color: var(--muted);
    }

    .post-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.3rem 1.5rem;
        margin-bottom: 0.9rem;
        transition: border-color 0.2s, transform 0.2s;
        position: relative;
        overflow: hidden;
        animation: fadeUp 0.4s ease both;
    }
    .post-card:hover { border-color: rgba(255,255,255,0.11); transform: translateY(-2px); }

    .post-card-inner-bar {
        position: absolute;
        top: 0; left: 0;
        width: 3px; height: 100%;
        background: var(--accent3);
        opacity: 0;
        transition: opacity 0.2s;
    }
    .post-card:hover .post-card-inner-bar { opacity: 1; }
    .post-card.flagged .post-card-inner-bar { background: var(--accent2); opacity: 1; }

    .post-top {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 0.9rem;
    }

    .post-avatar {
        width: 38px; height: 38px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--accent3), var(--accent2));
        flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        font: 700 0.85rem 'Space Mono', monospace;
        color: #fff;
    }

    .post-main { flex: 1; min-width: 0; }

    .post-title {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 1.35rem;
        letter-spacing: 0.8px;
        color: var(--text);
        margin-bottom: 0.4rem;
        line-height: 1.2;
    }

    .post-content {
        color: rgba(232,232,240,0.7);
        font-size: 0.9rem;
        line-height: 1.7;
    }

    .post-image {
        width: 100%;
        max-height: 380px;
        object-fit: cover;
        border-radius: 8px;
        margin: 0.8rem 0;
    }

    .post-footer {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 0.9rem;
        padding-top: 0.8rem;
        border-top: 1px solid var(--border);
    }

    .tag-chip {
        display: inline-flex;
        align-items: center;
        text-decoration: none;
        background: rgba(123,97,255,0.12);
        color: var(--accent3);
        border: 1px solid rgba(123,97,255,0.25);
        padding: 0.18rem 0.6rem;
        border-radius: 4px;
        font: 700 0.72rem 'Space Mono', monospace;
        letter-spacing: 0.5px;
        transition: background 0.2s;
    }
    .tag-chip:hover { background: rgba(123,97,255,0.25); }

    .post-time {
        font: 0.75rem 'Space Mono', monospace;
        color: var(--muted);
    }

    .spacer { margin-left: auto; }

    .like-info {
        display: flex;
        align-items: center;
        gap: 5px;
        font: 700 0.8rem 'Space Mono', monospace;
        color: var(--muted);
    }
    .like-info .count { color: var(--accent2); }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        text-decoration: none;
        border: none;
        border-radius: 5px;
        padding: 0.28rem 0.7rem;
        font: 600 0.76rem 'DM Sans', sans-serif;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.15s;
        white-space: nowrap;
    }
    .btn:hover { opacity: 0.8; transform: translateY(-1px); }
    .btn-like    { background: rgba(255,77,109,0.12); color: var(--accent2); border: 1px solid rgba(255,77,109,0.25); }
    .btn-unlike  { background: rgba(255,77,109,0.22); color: var(--accent2); border: 1px solid rgba(255,77,109,0.45); }
    .btn-delete  { background: rgba(255,60,60,0.12);  color: #ff6b6b; border: 1px solid rgba(255,60,60,0.25); }
    .btn-flag    { background: rgba(255,180,0,0.1);   color: #ffb400; border: 1px solid rgba(255,180,0,0.25); }
    .btn-unflag  { background: rgba(200,255,0,0.08);  color: var(--accent); border: 1px solid rgba(200,255,0,0.2); }

    .flag-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: rgba(255,77,109,0.1);
        border: 1px solid rgba(255,77,109,0.25);
        color: var(--accent2);
        border-radius: 4px;
        padding: 0.2rem 0.6rem;
        font: 700 0.72rem 'Space Mono', monospace;
        margin-bottom: 0.7rem;
    }

    .sidebar { position: sticky; top: 80px; }

    .sidebar-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.2rem;
        margin-bottom: 1rem;
    }

    .sidebar-heading {
        font: 700 0.72rem 'Space Mono', monospace;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.9rem;
    }

    .tag-list { display: flex; flex-wrap: wrap; gap: 0.4rem; }

    .tag-item {
        display: inline-block;
        text-decoration: none;
        background: var(--surface2);
        border: 1px solid var(--border);
        color: var(--text);
        padding: 0.28rem 0.65rem;
        border-radius: 4px;
        font: 0.78rem 'Space Mono', monospace;
        transition: all 0.2s;
    }
    .tag-item:hover {
        background: rgba(123,97,255,0.15);
        border-color: rgba(123,97,255,0.35);
        color: var(--accent3);
    }

    .error-banner {
        background: rgba(255,77,109,0.1);
        border: 1px solid rgba(255,77,109,0.25);
        border-radius: 8px;
        padding: 0.75rem 1rem;
        color: var(--accent2);
        font-size: 0.85rem;
        margin-bottom: 1rem;
    }

    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .field-input, .field-textarea, .field-select {
        width: 100%;
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text);
        padding: 0.65rem 0.9rem;
        font: 0.9rem 'DM Sans', sans-serif;
        outline: none;
        transition: border-color 0.2s;
        margin-bottom: 1rem;
        display: block;
    }
    .field-input:focus, .field-textarea:focus, .field-select:focus {
        border-color: rgba(200,255,0,0.5);
        box-shadow: 0 0 0 3px rgba(200,255,0,0.06);
    }
    .field-input::placeholder, .field-textarea::placeholder { color: var(--muted); }
    .field-textarea { min-height: 100px; resize: vertical; }
    .field-select { cursor: pointer; }
    .field-select option { background: var(--surface2); color: var(--text); }

    @media (max-width: 720px) {
        .explore-layout { grid-template-columns: 1fr; }
        .sidebar { display: none; }
    }
</style>

<div class="explore-layout">
    <main>
        <% if (errors) { %>
        <div class="error-banner">
            <% var errList = errors.toString().split(","); errList.forEach(function(e){ %><div>⚠ <%= e.trim() %></div><% }) %>
        </div>
        <% } %>

        <div class="composer">
            <div class="composer-trigger" id="composerTrigger">
                <div class="composer-avatar">+</div>
                <div class="composer-placeholder">What's on your mind?</div>
                <button type="button" class="composer-expand-btn" id="composerBtn">POST</button>
            </div>
            <div class="composer-body" id="composerBody">
                <form action="/explore/<%= profile.id %>/add" method="post">
                    <label class="field-label" style="margin-top:1rem;display:block;font:700 0.72rem 'Space Mono',monospace;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:0.4rem;">Title</label>
                    <input class="field-input" type="text" name="title" placeholder="Give it a title...">

                    <label class="field-label" style="display:block;font:700 0.72rem 'Space Mono',monospace;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:0.4rem;">Content</label>
                    <textarea class="field-textarea" name="content" placeholder="Write your post..."></textarea>

                    <label class="field-label" style="display:block;font:700 0.72rem 'Space Mono',monospace;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:0.4rem;">Tag</label>
                    <select class="field-select" name="id">
                        <option selected disabled>— Select a tag —</option>
                        <% tags.forEach(el => { %>
                        <option value="<%= el.id %>"><%= el.name %></option>
                        <% }) %>
                    </select>

                    <label class="field-label" style="display:block;font:700 0.72rem 'Space Mono',monospace;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:0.4rem;">Image URL <span style="font-weight:400;opacity:0.5">(optional)</span></label>
                    <input class="field-input" type="text" name="imageUrl" placeholder="https://...">

                    <div class="post-submit-row">
                        <span style="font:0.78rem 'Space Mono',monospace;color:var(--muted);">All fields required except image</span>
                        <button type="submit" class="post-submit-btn">PUBLISH →</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="feed-header">
            <h2 class="feed-heading">Latest Posts</h2>
            <span class="feed-count"><%= posts ? posts.length : 0 %> posts</span>
        </div>

        <% if (posts && posts.length) { %>
            <% posts.forEach((el, i) => { %>
            <article class="post-card <%= el.isFlagged ? 'flagged' : '' %>" style="animation-delay: <%= i * 0.05 %>s">
                <div class="post-card-inner-bar"></div>
                <% if (el.isFlagged) { %>
                <div class="flag-badge">⚠ Flagged by admin</div>
                <% } %>
                <div class="post-top">
                    <div class="post-avatar"><%= el.title.charAt(0).toUpperCase() %></div>
                    <div class="post-main">
                        <div class="post-title"><%= el.title %></div>
                        <div class="post-content"><%= el.content %></div>
                    </div>
                </div>
                <% if (el.imageUrl) { %>
                <img class="post-image" src="<%= el.imageUrl %>" alt="post image">
                <% } %>
                <div class="post-footer">
                    <a class="tag-chip" href="/explore/search?search=<%= el.Tags[0].name %>&searchBy=tag">#<%= el.Tags[0].name %></a>
                    <span class="post-time"><%= el.publishedTime %></span>
                    <div class="spacer"></div>
                    <span class="like-info">♥ <span class="count"><%= likeCounts[el.id] || 0 %></span></span>
                    <% if (likedPostIds.includes(el.id)) { %>
                    <a class="btn btn-unlike" href="/explore/<%= el.id %>/unlike">♥ Liked</a>
                    <% } else { %>
                    <a class="btn btn-like" href="/explore/<%= el.id %>/like">♡ Like</a>
                    <% } %>
                    <% if (el.ProfileId === profile.id || (isAdmin && el.isFlagged)) { %>
                    <a class="btn btn-delete" href="/profile/<%= el.ProfileId %>/post/<%= el.id %>/delete">✕ Delete</a>
                    <% } %>
                    <% if (isAdmin && !el.isFlagged) { %>
                    <a class="btn btn-flag" href="/explore/<%= el.id %>/flag">⚑ Flag</a>
                    <% } %>
                    <% if (isAdmin && el.isFlagged) { %>
                    <a class="btn btn-unflag" href="/explore/<%= el.id %>/unflag">↩ Unflag</a>
                    <% } %>
                </div>
            </article>
            <% }) %>
        <% } else { %>
        <div class="empty-state">
            <div style="font-size:2rem;margin-bottom:0.75rem;">◎</div>
            <div>No posts yet. Be the first to post.</div>
        </div>
        <% } %>
    </main>

    <aside class="sidebar">
        <div class="sidebar-card">
            <div class="sidebar-heading">Browse Tags</div>
            <div class="tag-list">
                <% tags.forEach(el => { %>
                <a class="tag-item" href="/explore/search?search=<%= el.name %>&searchBy=tag">#<%= el.name %></a>
                <% }) %>
            </div>
        </div>
        <div class="sidebar-card">
            <div class="sidebar-heading">Your Account</div>
            <div style="font-size:0.85rem;color:var(--muted);line-height:1.6;">
                <a href="/profile" style="color:var(--text);text-decoration:none;display:flex;align-items:center;gap:8px;padding:0.4rem 0;">
                    <div style="width:30px;height:30px;border-radius:50%;background:var(--accent3);display:flex;align-items:center;justify-content:center;font:700 0.75rem 'Space Mono',monospace;color:#fff;flex-shrink:0;">P</div>
                    <span>View Profile</span>
                </a>
            </div>
        </div>
    </aside>
</div>

<script>
    const composerBtn = document.getElementById('composerBtn');
    const composerBody = document.getElementById('composerBody');
    const composerPlaceholder = document.querySelector('.composer-placeholder');

    function toggleComposer() {
        const isOpen = composerBody.classList.toggle('open');
        composerBtn.classList.toggle('active', isOpen);
        composerBtn.textContent = isOpen ? 'CLOSE' : 'POST';
    }
    composerBtn.addEventListener('click', function(e) { e.stopPropagation(); toggleComposer(); });
    composerPlaceholder.addEventListener('click', function() { toggleComposer(); });
</script>
</body>
</html>
